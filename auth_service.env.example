# PostgreSQL (используется и приложением и docker-compose)
AUTH_POSTGRES_USER=postgres
AUTH_POSTGRES_PASSWORD=postgres
AUTH_POSTGRES_DB=auth_db
AUTH_POSTGRES_HOST=localhost
AUTH_POSTGRES_PORT=5436

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_TITLE=Auth Service
APP_VERSION=1.0.0
DEBUG=true
