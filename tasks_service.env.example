# PostgreSQL
TASKS_POSTGRES_USER=postgres
TASKS_POSTGRES_PASSWORD=postgres
TASKS_POSTGRES_DB=tasks_db
TASKS_POSTGRES_HOST=localhost
TASKS_POSTGRES_PORT=5435

# JWT (должен совпадать с Auth Service)
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256

# Auth Service URL
AUTH_SERVICE_URL=http://localhost:8000

# App
APP_TITLE=Tasks Service
APP_VERSION=1.0.0
DEBUG=true
